APP_NAME=Openmailer
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string
ENCRYPTION_KEY=change-this-to-a-32-char-hex-string-for-aes
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openmailer
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/openmailer
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
JWT_SECRET_KEY=change-this-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/outlook/callback
DEFAULT_SMTP_PORT=587
DEFAULT_IMAP_PORT=993
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=DEBUG
LOG_FORMAT=json
WARMUP_MIN_DAILY=5
WARMUP_MAX_DAILY=50
WARMUP_NETWORK_MIN_TRUST=50
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
ENABLE_OAUTH=true
ENABLE_WARMUP=true
ENABLE_BILLING=false
